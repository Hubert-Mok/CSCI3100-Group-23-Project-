<% content_for :title, "Payment Received – CUHK Marketplace" %>

<div class="form-page">
  <div class="form-page-header">
    <h1>Payment Received</h1>
    <p>Your payment has been received and is held securely. Once you receive the item, go to your order and click &ldquo;Confirm I Received the Item&rdquo; so we can release the payment to the seller.</p>
  </div>

  <p class="order-window-hint">Next step: meet the seller and confirm receipt in your order page.</p>
  <div class="order-success-actions">
    <%= link_to "View order", @order, class: "btn-primary" %>
    <%= link_to "Back to listings", root_path, class: "btn-secondary" %>
  </div>
</div>
