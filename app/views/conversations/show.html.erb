<% content_for :title, "Chat – #{@conversation.product.title} – CUHK Marketplace" %>

<%= turbo_stream_from @conversation %>

<div class="conversation-show">
  <div class="conversation-show-header">
    <div>
      <h1>Chat about "<%= @conversation.product.title %>"</h1>
      <p>
        <% other_user =
             @conversation.buyer_id == current_user.id ? @conversation.seller : @conversation.buyer %>
        Talking with <strong><%= other_user.username %></strong>
        &middot;
        <%= other_user.college_affiliation %>
      </p>
    </div>
    <div class="conversation-header-actions">
      <%= link_to "View listing", product_path(@conversation.product), class: "btn-secondary btn-sm" %>
      <%= button_to "Delete chat",
                    conversation_path(@conversation),
                    method: :delete,
                    class: "btn-secondary btn-delete btn-sm",
                    data: { turbo_confirm: "Hide this chat from your inbox? If both users hide it, it will be permanently deleted." } %>
    </div>
  </div>

  <div class="conversation-layout">
    <div class="offer-panel">
      <% if @conversation.product.available? && @conversation.product.sale? %>
        <% if current_user == @conversation.buyer %>
          <%= form_with model: [@conversation, @offer], class: "offer-form" do |f| %>
            <div class="offer-form-row">
              <%= f.number_field :amount, min: 1, step: 1, placeholder: "Propose amount (HKD)", class: "offer-input" %>
              <%= f.submit "Send Offer", class: "btn-primary btn-sm" %>
            </div>
          <% end %>
        <% else %>
          <p class="offer-hint">Offers can be initiated by the buyer. You can accept, reject, or counter incoming offers.</p>
        <% end %>
      <% else %>
        <p class="offer-hint">Offers are only available for sale listings that are still available.</p>
      <% end %>

      <% if @offers.any? %>
        <div class="offer-list">
          <% @offers.each do |offer| %>
            <%= render "offers/offer", offer: offer, conversation: @conversation %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div id="<%= dom_id(@conversation, :messages) %>"
         class="conversation-messages"
         data-controller="auto-scroll">
      <% if @messages.any? %>
        <% @messages.each do |message| %>
          <%= render "messages/message", message: message %>
        <% end %>
      <% else %>
        <div class="conversation-empty-hint">
          Start the conversation by saying hi 👋
        </div>
      <% end %>
    </div>

    <div id="<%= dom_id(@conversation, :new_message) %>" class="conversation-form">
      <%= form_with model: [@conversation, @message], class: "message-form" do |f| %>
        <div class="message-form-field">
          <%= f.text_area :body,
                          rows: 2,
                          placeholder: "Type your message...",
                          class: "message-input" %>
        </div>
        <div class="message-form-field">
          <%= f.file_field :attachments, multiple: true, accept: "image/*,.pdf,.doc,.docx", class: "message-file-input" %>
          <p class="message-form-hint">Photos and files (optional)</p>
        </div>
        <div class="message-form-actions">
          <%= f.submit "Send", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

