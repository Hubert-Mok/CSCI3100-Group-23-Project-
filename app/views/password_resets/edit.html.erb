<% content_for :title, "Reset Password – CUHK Marketplace" %>

<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">Set a new password</h1>
    <p class="auth-subtitle">Choose a strong password for your CUHK Marketplace account.</p>

    <% if @user.errors.any? %>
      <div class="error-messages">
        <ul>
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with url: password_reset_path, method: :patch, class: "auth-form" do |f| %>
      <%= hidden_field_tag :token, @token %>

      <div class="form-group">
        <%= label_tag :password, "New password" %>
        <%= password_field_tag :password, nil, placeholder: "Min. 6 characters", autocomplete: "new-password", required: true %>
      </div>

      <div class="form-group">
        <%= label_tag :password_confirmation, "Confirm new password" %>
        <%= password_field_tag :password_confirmation, nil, placeholder: "Re-enter password", autocomplete: "new-password", required: true %>
      </div>

      <%= submit_tag "Reset password", class: "btn-primary" %>
    <% end %>

    <p class="auth-footer">
      <%= link_to "Back to Sign In", sign_in_path %>
    </p>
  </div>
</div>
