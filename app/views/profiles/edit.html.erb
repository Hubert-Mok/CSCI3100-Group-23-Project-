<% content_for :title, "Edit Profile – CUHK Marketplace" %>

<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css">
<% end %>

<div class="form-page">
  <div class="form-page-header">
    <h1>Edit Profile</h1>
    <p>Update your account information.</p>
  </div>

  <% if @user.errors.any? %>
    <div class="error-messages">
      <p><strong><%= pluralize(@user.errors.count, "error") %> prevented your profile from being saved:</strong></p>
      <ul>
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @user, url: profile_path, method: :patch, class: "auth-form", multipart: true do |f| %>
    <div class="form-group avatar-upload-group" data-controller="avatar-crop">
      <label>Profile Photo</label>

      <%# Live preview — updates after crop %>
      <div class="avatar-upload-preview" data-avatar-crop-target="previewWrap">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar.variant(resize_to_fill: [96, 96]),
                class: "avatar-upload-current", alt: "Current avatar" %>
        <% else %>
          <div class="avatar-upload-initials"><%= @user.username.first(2).upcase %></div>
        <% end %>
      </div>

      <%# Visible button — opens the file picker %>
      <button type="button" class="btn-primary btn-sm"
              data-action="click->avatar-crop#openPicker">Choose Photo</button>

      <%# Non-submitted trigger input — used only to pick the source image %>
      <input type="file" accept="image/*" style="display:none"
             data-avatar-crop-target="triggerInput"
             data-action="change->avatar-crop#onFileChange">

      <%# Real submitted input — receives the cropped blob via JavaScript %>
      <input type="file" name="user[avatar]" style="display:none"
             data-avatar-crop-target="hiddenInput">

      <span class="static-hint">JPG or PNG, square crop will be applied.</span>

      <%# Crop modal %>
      <div class="avatar-crop-modal" data-avatar-crop-target="modal" style="display:none">
        <div class="avatar-crop-dialog">
          <h3 class="avatar-crop-title">Adjust Photo</h3>
          <div class="avatar-crop-image-wrap">
            <img data-avatar-crop-target="cropImage" src="" alt="Crop preview">
          </div>
          <div class="avatar-crop-actions">
            <button type="button" class="btn-primary"
                    data-action="click->avatar-crop#cropAndSave">Crop &amp; Save</button>
            <button type="button" class="btn-secondary"
                    data-action="click->avatar-crop#cancel">Cancel</button>
          </div>
        </div>
      </div>
    </div>

    <div class="form-group">
      <%= f.label :username, "Username" %>
      <%= f.text_field :username, required: true, autocomplete: "username" %>
    </div>

    <div class="form-group">
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, required: true, autocomplete: "email" %>
    </div>

    <div class="form-group">
      <%= f.label :college_affiliation, "College" %>
      <%= f.select :college_affiliation,
            options_for_select(User::COLLEGES, @user.college_affiliation),
            { include_blank: "Select your college" },
            { required: true } %>
    </div>

    <div class="form-group form-group-static">
      <span class="static-label">CUHK Student ID</span>
      <span class="static-value"><%= @user.cuhk_id %></span>
      <span class="static-hint">Student ID cannot be changed after registration.</span>
    </div>

    <%= f.submit "Save Changes", class: "btn-primary" %>
  <% end %>

  <p class="auth-footer"><%= link_to "← Cancel", profile_path %></p>
</div>
