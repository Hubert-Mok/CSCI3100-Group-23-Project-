<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Cuhk Market Place" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cuhk Market Place">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-theme="<%= logged_in? && current_user.dark_theme? ? "dark" : "light" %>">
    <header class="site-header">
      <nav class="nav-container">
        <div class="nav-brand">
          <%= link_to "CUHK Marketplace", root_path %>
        </div>
        <div class="nav-search">
          <%= form_with url: products_path, method: :get, local: true, class: "nav-search-form" do |f| %>
            <%= f.text_field :q,
                             value: params[:q],
                             placeholder: "Search for textbooks, electronics, furniture...",
                             class: "nav-search-input",
                             aria: { label: "Search listings" } %>
            <%= f.submit "Search", class: "btn-primary nav-search-button" %>
          <% end %>
        </div>
        <div class="nav-links">
          <% if logged_in? %>
            <%= turbo_stream_from "notifications:#{current_user.id}" %>
            <div class="nav-notifications" data-controller="notifications">
              <button type="button" data-action="click->notifications#toggle" class="nav-notification-trigger" aria-label="Notifications">
                <span class="nav-notification-icon" aria-hidden="true">🔔</span>
                <% unread_count = current_user.notifications.unread.count %>
                <span id="notification_badge" class="notification-badge" style="<%= 'display: none;' if unread_count.zero? %>"><%= unread_count %></span>
              </button>
              <div data-notifications-target="panel" class="notifications-dropdown" id="notifications_dropdown_panel">
                <div class="notifications-dropdown-header">
                  <span>Notifications</span>
                  <%= button_to "Clear all",
                                clear_all_notifications_path,
                                method: :delete,
                                class: "notifications-clear-all",
                                form: { data: { turbo_confirm: "Clear all notifications?" } } %>
                </div>
                <div id="notifications_list" class="notifications-list">
                  <% if current_user.notifications.recent.limit(10).none? %>
                    <div class="notifications-empty">No notifications yet.</div>
                  <% else %>
                    <% current_user.notifications.recent.limit(10).each do |notification| %>
                      <%= render "notifications/notification", notification: notification %>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
            <%= link_to "Sell", new_product_path, class: "btn-primary nav-btn" %>
            <%= button_to (current_user.dark_theme? ? "Light Mode" : "Dark Mode"),
                          profile_path,
                          method: :patch,
                          params: { user: { theme_preference: (current_user.dark_theme? ? "light" : "dark") } },
                          class: "btn-secondary nav-btn" %>
            <%= link_to "Orders", orders_path, class: "nav-link" %>
            <% unread_messages_count = unread_conversations_count_for(current_user) %>
            <%= link_to conversations_path, class: "nav-link nav-link-messages" do %>
              <span>Messages</span>
              <% if unread_messages_count.positive? %>
                <span class="messages-badge"><%= unread_messages_count > 99 ? "99+" : unread_messages_count %></span>
              <% end %>
            <% end %>
            <%= link_to "Profile", profile_path, class: "nav-link" %>
            <% if current_user&.admin? %>
              <% flagged_products_count = Product.flagged_for_review.count %>
              <% flagged_messages_count = Message.where(flagged: true).count %>
              <% total_review_count = flagged_products_count + flagged_messages_count %>
              <%= link_to admin_moderation_index_path, class: "btn-admin nav-btn admin-dashboard-link" do %>
                <span>Admin Dashboard</span>
                <% if total_review_count.positive? %>
                  <span class="admin-badge" aria-label="<%= total_review_count %> items need review"><%= total_review_count > 99 ? '99+' : total_review_count %></span>
                <% end %>
              <% end %>
            <% end %>
            <%= button_to "Sign Out", sign_out_path, method: :delete, class: "btn-secondary", form: { data: { turbo: false } } %>
          <% else %>
            <%= link_to "Sign In", sign_in_path, class: "nav-link" %>
            <%= link_to "Sign Up", sign_up_path, class: "btn-primary nav-btn" %>
          <% end %>
        </div>
      </nav>
    </header>

    <% if flash.any? %>
      <div class="flash-wrap">
        <% flash.each do |type, message| %>
          <div class="flash flash-<%= type %>"><%= message %></div>
        <% end %>
      </div>
    <% end %>

    <main class="main-content">
      <%= yield %>
    </main>
  </body>
</html>
